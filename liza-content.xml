		<wp:status><![CDATA[publish]]></wp:status>
		<wp:post_type><![CDATA[page]]></wp:post_type>
	</item>
	<item>
		<title><![CDATA[Reserve a Table]]></title>
		<link>https://example.com/contact/</link>
		<dc:creator><![CDATA[admin]]></dc:creator>
		<content:encoded><![CDATA[<p>We would love to welcome you to Savoria. To reserve a table, please call us or send a message.</p><p><strong>Address:</strong> 24 Garden Street, City Centre<br><strong>Phone:</strong> +1 (555) 123-4567<br><strong>Email:</strong> hello@savoria.com</p><p><strong>Opening Hours:</strong><br>Monday – Friday: 12:00 – 22:00<br>Saturday – Sunday: 10:00 – 23:00</p>]]></content:encoded>
